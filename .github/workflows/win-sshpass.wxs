<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="win-sshpass" Version="$(var.Version)"
           Manufacturer="win-sshpass" UpgradeCode="a1b2c3d4-e5f6-7890-abcd-ef1234567890"
           InstallerVersion="500" Scope="perMachine" Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main" Title="win-sshpass" Level="1">
      <ComponentGroupRef Id="MainComponents" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLDIR" Name="win-sshpass">
        <Component Id="MainExe" Guid="*">
          <File Id="MainFile" Source="win-sshpass.exe" KeyPath="yes" />
        </Component>

        <Component Id="PathEnv" Guid="*">
          <Environment Id="PATH_Env" Name="PATH"
                       Value="[INSTALLDIR]" Permanent="no"
                       Part="last" Action="set" System="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <ComponentGroup Id="MainComponents">
      <ComponentRef Id="MainExe" />
      <ComponentRef Id="PathEnv" />
    </ComponentGroup>

  </Package>
</Wix>
